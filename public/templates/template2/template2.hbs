
      <!DOCTYPE html>
      <html lang="en">
        <head>
            <meta charset="UTF-8">
            <meta name="viewport" content="width=device-width, initial-scale=1.0">
            <title>{{firstName}} {{lastName}} - Resume</title>
                <style>.resume-container{font-family:'Segoe UI',Tahoma,Geneva,Verdana,sans-serif;line-height:1.6;display:flex;max-width:1200px;margin:0 auto;background:white;box-shadow:0 4px 20px rgba(0,0,0,0.1);min-height:100vh;color:#333;background-color:#f8f9fa;}.sidebar{width:320px;background:linear-gradient(135deg,#667eea 0%,#764ba2 100%);color:white;padding:40px 30px;position:relative;}.sidebar::before{content:'';position:absolute;top:0;left:0;right:0;bottom:0;background:rgba(0,0,0,0.1);z-index:1;}.sidebar>*{position:relative;z-index:2;}.profile-section{text-align:center;margin-bottom:40px;}.profile-image{margin-bottom:20px;}.profile-initials{width:80px;height:80px;background:rgba(255,255,255,0.2);border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:28px;font-weight:bold;margin:0 auto;border:3px solid rgba(255,255,255,0.3);position:relative;overflow:hidden;}.first-initial,.last-initial{display:block;overflow:hidden;white-space:nowrap;text-transform:capitalize;}.first-initial::first-letter,.last-initial::first-letter{font-size:28px;font-weight:bold;color:white;}.first-initial,.last-initial{font-size:0;color:transparent;}.full-name{font-size:28px;font-weight:700;margin-bottom:8px;text-transform:uppercase;letter-spacing:1px;}.job-title{font-size:16px;font-weight:400;opacity:0.9;text-transform:uppercase;letter-spacing:0.5px;}.section-title{font-size:18px;font-weight:600;margin-bottom:20px;text-transform:uppercase;letter-spacing:0.5px;border-bottom:2px solid rgba(255,255,255,0.3);padding-bottom:8px;color:white;}.contact-section{margin-bottom:40px;}.contact-item{display:flex;align-items:center;margin-bottom:15px;}.contact-icon{font-size:18px;margin-right:12px;width:24px;text-align:center;}.contact-text{font-size:14px;opacity:0.9;}.skills-section{margin-bottom:40px;}.skills-grid{display:flex;flex-direction:column;gap:12px;}.skill-item{background:rgba(255,255,255,0.2);padding:8px 12px;border-radius:8px;border:1px solid rgba(255,255,255,0.3);}.skill-name{display:block;font-size:14px;font-weight:500;margin-bottom:6px;}.skill-level{margin-top:6px;}.skill-bar{width:100%;height:4px;background:rgba(255,255,255,0.2);border-radius:2px;overflow:hidden;}.skill-progress{height:100%;background:rgba(255,255,255,0.8);border-radius:2px;transition:width 0.3s ease;}.main-content{flex:1;padding:40px 50px;background:white;}.main-content .section-title{color:#667eea;border-bottom:2px solid #e9ecef;margin-bottom:25px;padding-bottom:10px;}.about-section{margin-bottom:40px;}.about-text{font-size:16px;line-height:1.8;color:#555;}.experience-section{margin-bottom:40px;}.experience-item{margin-bottom:30px;padding-bottom:25px;border-bottom:1px solid #f1f3f4;}.experience-item:last-child{border-bottom:none;}.experience-header{margin-bottom:8px;}.experience-title{font-size:20px;font-weight:600;color:#333;margin-bottom:4px;}.experience-company{font-size:16px;color:#667eea;font-weight:500;}.experience-meta{display:flex;gap:20px;margin-bottom:12px;font-size:14px;color:#666;}.experience-description{font-size:15px;line-height:1.7;color:#555;}.education-section{margin-bottom:40px;}.education-item{margin-bottom:25px;padding-bottom:20px;border-bottom:1px solid #f1f3f4;}.education-item:last-child{border-bottom:none;}.education-header{margin-bottom:8px;}.education-degree{font-size:18px;font-weight:600;color:#333;margin-bottom:4px;display:block;}.education-university{font-size:15px;color:#667eea;font-weight:500;}.education-meta{display:flex;gap:20px;margin-bottom:10px;font-size:14px;color:#666;}.education-description{font-size:14px;line-height:1.6;color:#555;}@media (max-width:768px){.resume-container{flex-direction:column;}.sidebar{width:100%;padding:30px 20px;}.main-content{padding:30px 20px;}.experience-meta,.education-meta{flex-direction:column;gap:5px;}}@media print{.resume-container{box-shadow:none;max-width:none;}.sidebar{background:#667eea !important;}}</style>
        </head>
        <body>
          <div class="resume-container">
	<!-- Sidebar -->
	<div class="sidebar">
		<div class="profile-section">
			<div class="profile-image">
				<div class="profile-initials">
					<span class="first-initial">{{firstName}}</span><span class="last-initial">{{lastName}}</span>
				</div>
			</div>
			<h1 class="full-name">{{firstName}} {{lastName}}</h1>
			<h2 class="job-title">{{role}}</h2>
		</div>

		<div class="contact-section">
			<h3 class="section-title">Contact</h3>
			<div class="contact-item">
				<div class="contact-icon">📍</div>
				<div class="contact-text">{{city}}, {{postalCode}}</div>
			</div>
			<div class="contact-item">
				<div class="contact-icon">📱</div>
				<div class="contact-text">{{phone}}</div>
			</div>
			<div class="contact-item">
				<div class="contact-icon">✉️</div>
				<div class="contact-text">{{email}}</div>
			</div>
			<div class="contact-item">
				<div class="contact-icon">🔗</div>
				<div class="contact-text">{{#ifNotEmpty linkedin}}{{linkedin}}{{/ifNotEmpty}}</div>
			</div>
			<div class="contact-item">
				<div class="contact-icon">💻</div>
				<div class="contact-text">{{#ifNotEmpty github}}{{github}}{{/ifNotEmpty}}</div>
			</div>
		</div>

		<!-- Skills -->
		<div class="skills-section">
			<h3 class="section-title">Skills</h3>
			<div class="skills-grid">
				{{#each skills}}
				<div class="skill-item">
					<span class="skill-name">{{title}}</span>
					<div class="skill-level">
						<div class="skill-bar">
							<div class="skill-progress" style="width: {{skillLevel level}}%"></div>
						</div>
					</div>
				</div>
				{{/each}}
			</div>
		</div>
	</div>

	<!-- Main Content -->
	<div class="main-content">
		<div class="about-section">
			<h3 class="section-title">About Me</h3>
			<p class="about-text">{{aboutMe}}</p>
		</div>

		<!-- Work Experience -->
		<div class="experience-section">
			<h3 class="section-title">Work Experience</h3>
			{{#each workExperience}}
			<div class="experience-item">
				<div class="experience-header">
					<h4 class="experience-title">{{jobTitle}}</h4>
					<span class="experience-company">{{company}}</span>
				</div>
				<div class="experience-meta">
					<span class="experience-date">{{formatDate startDate 'MMM yyyy'}} - {{formatDate endDate 'MMM yyyy'}}</span>
					<span class="experience-location">{{location}}</span>
				</div>
				<p class="experience-description">{{description}}</p>
			</div>
			{{/each}}
		</div>

		<!-- Education -->
		<div class="education-section">
			<h3 class="section-title">Education</h3>
			{{#each education}}
			<div class="education-item">
				<div class="education-header">
					<h4 class="education-degree">{{degree}}</h4>
					<span class="education-university">{{university}}</span>
				</div>
				<div class="education-meta">
					<span class="education-date">Finished: {{formatDate finishDate 'PPP'}}</span>
					<span class="education-location">{{city}}</span>
				</div>
				<p class="education-description">{{description}}</p>
			</div>
			{{/each}}
		</div>
	</div>
</div>

        </body>
      </html>