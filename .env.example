# Auth
GITHUB_ID=
GITHUB_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
NEXTAUTH_SECRET=
AUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Vercel Flags
FLAGS=

# CMS API
NEXT_PUBLIC_CMS_API_URL=

# AI
GROQ_API_KEY=

# CMS OAuth
# Dedicated salt for deriving CMS passwords from Google OAuth IDs.
# Intentionally separate from AUTH_SECRET so JWT key rotation doesn't
# invalidate CMS accounts and a CMS credential leak doesn't expose session tokens.
CMS_OAUTH_SALT=

# Feature Flags (Hypertune)
EXPERIMENTATION_CONFIG_ITEM_KEY=
NEXT_PUBLIC_HYPERTUNE_TOKEN=
HYPERTUNE_FRAMEWORK=nextApp
HYPERTUNE_OUTPUT_DIRECTORY_PATH=generated

# App Config
NEXT_PUBLIC_PAGE_LIMIT=6
